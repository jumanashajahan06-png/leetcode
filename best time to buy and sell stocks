class Solution {
    public int maxProfit(int[] prices) {
        int min_price = Integer.MAX_VALUE;
        int maxProfit = 0;

        for (int price : prices) {
            if (price < min_price) {
                min_price = price;
            } else {
                int profit = price - min_price;
                maxProfit = Math.max(maxProfit, profit);
            }
        }

        return maxProfit;
    }
}
